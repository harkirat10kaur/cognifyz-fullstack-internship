<%- include('partials/header') %>

<main class="main-container">

  <!-- LEFT: Form Section -->
  <section class="form-section">
    <div class="form-card">
      <h2 class="form-title">Submit Feedback</h2>
      <p class="form-subtitle">Your thoughts help us build better.</p>

      <!-- Flash Messages -->
      <% if (success.length > 0) { %>
        <div class="flash flash-success"><%= success[0] %></div>
      <% } %>
      <% if (error.length > 0) { %>
        <div class="flash flash-error"><%= error[0] %></div>
      <% } %>

      <form action="/submit" method="POST">

        <div class="form-group">
          <label for="name">Your Name</label>
          <input type="text" id="name" name="name" placeholder="e.g. Harkirat Kaur" required />
        </div>

        <div class="form-group">
          <label for="category">Category</label>
          <select id="category" name="category" required>
            <option value="" disabled selected>Select a category</option>
            <option value="Bug">🐛 Bug Report</option>
            <option value="Feature">✨ Feature Request</option>
            <option value="Idea">💡 Idea</option>
            <option value="Other">📝 Other</option>
          </select>
        </div>

        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" placeholder="Describe your feedback in detail..." required></textarea>
        </div>

        <button type="submit" class="submit-btn">Submit Feedback →</button>

      </form>
    </div>
  </section>

  <!-- RIGHT: Feedback Feed -->
  <section class="feed-section">
    <h2 class="feed-title">Community Feedback <span class="count-badge"><%= feedbacks.length %></span></h2>

    <% if (feedbacks.length === 0) { %>
      <div class="empty-state">
        <p>🌱 No feedback yet. Be the first to submit!</p>
      </div>
    <% } else { %>
      <div class="feed-list">
        <% feedbacks.forEach(function(fb) { %>
          <div class="feed-card category-<%= fb.category.toLowerCase() %>">
            <div class="feed-card-header">
              <span class="feed-name"><%= fb.name %></span>
              <span class="feed-category"><%= fb.category %></span>
            </div>
            <p class="feed-message"><%= fb.message %></p>
            <span class="feed-date"><%= fb.date %></span>
          </div>
        <% }); %>
      </div>
    <% } %>
  </section>

</main>

<%- include('partials/footer') %>